# Production Environment Variables for AWS Lightsail / EC2 deployment

# 1. Supabase Connection Strings (Transaction mode: remove ?pgbouncer=true or any connection pooler arguments if using direct connection for migrations, or keep it if using session mode pooler)
DATABASE_URLS=postgresql://postgres:password_shard1@db.shard1.supabase.co:5432/postgres,postgresql://postgres:password_shard2@db.shard2.supabase.co:5432/postgres

# 2. Upstash Redis Connection String
REDIS_URL=rediss://default:token@endpoint.upstash.io:6379

# 3. Domain Configuration
DOMAIN=api.mytinyurl.com
APP_URL=https://api.mytinyurl.com
CORS_ORIGINS=https://mytinyurl.com

# 4. App Settings
DEFAULT_EXPIRATION_HOURS=24
MACHINE_ID=1 # Change this per server if scaling horizontally
