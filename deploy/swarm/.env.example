# DNS and TLS
APP_DOMAIN=go.seudominio.com
APP_URL=https://go.seudominio.com
LETSENCRYPT_EMAIL=ops@seudominio.com

# Frontend origins allowed to call the API
CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com,https://mytinyurl.pages.dev

# Supabase shards
# Use direct Postgres URLs when the VPS has IPv6.
# If your VPS is IPv4-only, switch each URL to Supavisor session mode on port 5432.
DATABASE_URLS=postgresql://postgres:senha@db.projeto-shard-1.supabase.co:5432/postgres,postgresql://postgres:senha@db.projeto-shard-2.supabase.co:5432/postgres

# Swarm sizing
BACKEND_REPLICAS=1
WORKER_REPLICAS=1

# App runtime
DEFAULT_EXPIRATION_HOURS=24
MACHINE_ID=1
ENABLE_DOCS=false
ADMIN_TOKEN=troque-por-um-token-longo-e-aleatorio
BLOCK_PRIVATE_TARGETS=true
MAX_URL_LENGTH=2048
MAX_REQUEST_BODY_BYTES=4096
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_SHORTEN=20
RATE_LIMIT_MAX_STATS=30
RATE_LIMIT_MAX_REDIRECT=300
RATE_LIMIT_MAX_HEALTH=60
