{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "dist/**/*"
            ]
        },
        "lint": {},
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "cache": false,
            "persistent": true
        },
        "test": {},
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "test:coverage": {
            "outputs": [
                "coverage/**"
            ]
        }
    }
}