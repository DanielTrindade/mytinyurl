# Database (comma-separated for multiple shards)
# Single shard:  DATABASE_URLS=postgresql://user:pass@host:5432/mydb
# Multi shard:   DATABASE_URLS=postgresql://...:5432/mydb,postgresql://...:5434/mydb
DATABASE_URLS=

# Server
PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development
ENABLE_DOCS=true
ADMIN_TOKEN=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# URL / Security Settings
DEFAULT_EXPIRATION_HOURS=24
BLOCK_PRIVATE_TARGETS=true
MAX_URL_LENGTH=2048
MAX_REQUEST_BODY_BYTES=4096
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_SHORTEN=20
RATE_LIMIT_MAX_STATS=30
RATE_LIMIT_MAX_REDIRECT=300
RATE_LIMIT_MAX_HEALTH=60

# Redis
# Dev:  redis://localhost:6379
# Prod: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# Snowflake ID: machine identifier (0-1023)
MACHINE_ID=1
